{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ralphharness",
  "title": "RalphHarness Specification Schema",
  "description": "Schema for ralphharness state files and spec document frontmatter",

  "definitions": {
    "state": {
      "type": "object",
      "description": "Runtime state for spec execution loop",
      "required": ["source", "name", "basePath", "phase"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["spec", "plan", "direct"],
          "description": "Origin of tasks: spec (full workflow), plan (skip to tasks), direct (manual tasks.md)"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Spec name in kebab-case"
        },
        "basePath": {
          "type": "string",
          "description": "Path to spec directory (e.g., ./specs/my-feature)"
        },
        "phase": {
          "type": "string",
          "enum": ["research", "requirements", "design", "tasks", "execution"],
          "description": "Current workflow phase"
        },
        "taskIndex": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Current task index (0-based)"
        },
        "totalTasks": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Total number of tasks in tasks.md"
        },
        "taskIteration": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Current iteration for this task (resets per task)"
        },
        "repairIteration": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Current repair iteration count for recovery mode"
        },
        "failedStory": {
          "type": ["string", "null"],
          "description": "ID of the story that failed, for recovery tracking"
        },
        "originTaskIndex": {
          "type": ["integer", "null"],
          "description": "Original task index before fix task insertion"
        },
        "awaitingApproval": {
          "type": "boolean",
          "default": false,
          "description": "Whether execution is waiting for external approval"
        },
        "maxTaskIterations": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Max retries per task before failure"
        },
        "globalIteration": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Total loop iterations across all tasks"
        },
        "maxGlobalIterations": {
          "type": "integer",
          "minimum": 1,
          "default": 100,
          "description": "Safety cap on total iterations"
        },
        "relatedSpecs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "relevance": { "enum": ["high", "medium", "low"] },
              "reason": { "type": "string" },
              "mayNeedUpdate": { "type": "boolean" }
            },
            "required": ["name", "relevance", "reason"]
          },
          "description": "Existing specs related to this one"
        },
        "parallelGroup": {
          "type": "object",
          "description": "Current parallel task group being executed",
          "properties": {
            "startIndex": {
              "type": "integer",
              "minimum": 0,
              "description": "First task index in current parallel group"
            },
            "endIndex": {
              "type": "integer",
              "minimum": 0,
              "description": "Last task index in current parallel group"
            },
            "taskIndices": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 },
              "description": "All task indices in the parallel group"
            }
          },
          "required": ["startIndex", "endIndex", "taskIndices"]
        },
        "taskResults": {
          "type": "object",
          "description": "Per-task execution results for parallel batch",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pending", "success", "failed"],
                "description": "Task execution status"
              },
              "error": {
                "type": "string",
                "description": "Error message if task failed"
              }
            },
            "required": ["status"]
          }
        },
        "recoveryMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable iterative failure recovery"
        },
        "maxFixTasksPerOriginal": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Max fix tasks allowed per original task"
        },
        "maxFixTaskDepth": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Max depth for fix task chains"
        },
        "fixTaskMap": {
          "type": "object",
          "description": "Tracks fix attempts per original task",
          "default": {},
          "additionalProperties": {
            "type": "object",
            "properties": {
              "attempts": { "type": "integer", "minimum": 0 },
              "fixTaskIds": { "type": "array", "items": { "type": "string" } },
              "lastError": { "type": "string" }
            },
            "required": ["attempts", "fixTaskIds"]
          }
        },
        "modificationMap": {
          "type": "object",
          "description": "Tracks modification requests per original task",
          "default": {},
          "additionalProperties": {
            "type": "object",
            "properties": {
              "count": { "type": "integer", "minimum": 0 },
              "modifications": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "type": { "type": "string", "enum": ["SPLIT_TASK", "ADD_PREREQUISITE", "ADD_FOLLOWUP"] },
                    "reason": { "type": "string" }
                  },
                  "required": ["id", "type"]
                }
              }
            },
            "required": ["count", "modifications"]
          }
        },
        "maxModificationsPerTask": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Max modification requests allowed per original task"
        },
        "maxModificationDepth": {
          "type": "integer",
          "minimum": 1,
          "default": 2,
          "description": "Max nesting depth for modification task IDs"
        },
        "epicName": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Parent epic name if this spec belongs to an epic"
        },
        "granularity": {
          "type": "string",
          "enum": ["fine", "coarse"],
          "description": "Task sizing level: fine (40-60+ tasks) or coarse (10-20 tasks)"
        },
        "nativeTaskMap": {
          "type": "object",
          "description": "Maps taskIndex to native task IDs for external sync",
          "default": {},
          "additionalProperties": {
            "type": "string"
          }
        },
        "nativeSyncEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether native task sync is active"
        },
        "nativeSyncFailureCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Consecutive native sync failures (disables at 3)"
        },
        "chat": {
          "type": "object",
          "description": "Chat protocol state for external reviewer coordination",
          "properties": {
            "executor": {
              "type": "object",
              "properties": {
                "lastReadLine": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 0,
                  "description": "Last line read in chat.md by executor"
                }
              }
            }
          }
        },
        "checkpoint": {
          "type": "object",
          "description": "Pre-execution git checkpoint for rollback safety",
          "properties": {
            "sha": {
              "type": ["string", "null"],
              "description": "Full 40-char git commit SHA at checkpoint"
            },
            "timestamp": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "ISO 8601 UTC timestamp when checkpoint was created"
            },
            "branch": {
              "type": ["string", "null"],
              "description": "Git branch name at checkpoint"
            },
            "message": {
              "type": ["string", "null"],
              "description": "Checkpoint commit message"
            }
          }
        },
        "circuitBreaker": {
          "type": "object",
          "description": "Session circuit breaker for safety",
          "properties": {
            "state": {
              "type": ["string", "null"],
              "enum": ["closed", "open", null],
              "description": "Circuit breaker state: closed (normal), open (blocked), or null"
            },
            "consecutiveFailures": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Count of consecutive session failures"
            },
            "sessionStartTime": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "ISO 8601 UTC timestamp when current session started"
            },
            "openedAt": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "ISO 8601 UTC timestamp when circuit breaker tripped open"
            },
            "trippedReason": {
              "type": ["string", "null"],
              "description": "Reason the circuit breaker was tripped open"
            },
            "maxConsecutiveFailures": {
              "type": "integer",
              "minimum": 1,
              "default": 5,
              "description": "Max consecutive failures before tripping open"
            },
            "maxSessionSeconds": {
              "type": "integer",
              "minimum": 1,
              "default": 172800,
              "description": "Max session duration in seconds before tripping open"
            }
          }
        },
        "filesystemHealthy": {
          "type": "boolean",
          "description": "Whether the filesystem is healthy and writable"
        },
        "filesystemHealthFailures": {
          "type": "integer",
          "description": "Number of consecutive filesystem health check failures",
          "default": 0
        },
        "lastFilesystemCheck": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Timestamp of last filesystem health check"
        },
        "ciCommands": {
          "type": "array",
          "items": {"$ref": "#/definitions/ciCommand"},
          "description": "List of CI commands discovered at execution start, classified by category"
        },
        "ciSnapshot": {
          "type": "object",
          "description": "Per-category CI execution results recorded after Layer 3 quality checkpoints",
          "properties": {
            "lint": {"$ref": "#/definitions/ciResult"},
            "typecheck": {"$ref": "#/definitions/ciResult"},
            "test": {"$ref": "#/definitions/ciResult"},
            "build": {"$ref": "#/definitions/ciResult"},
            "other": {"$ref": "#/definitions/ciResult"}
          }
        },
        "signals": {
          "type": "object",
          "description": "Signal event log state for audit/diff replay",
          "properties": {
            "lastProcessedLine": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Coordinators read cursor for replay/diff; active-signal check always rescans the full file"
            }
          }
        }
      }
    },

    "epicState": {
      "type": "object",
      "description": "State for epic (multi-spec) tracking",
      "required": ["name", "goal", "specs"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Epic name in kebab-case"
        },
        "goal": {
          "type": "string",
          "description": "High-level epic goal"
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "status", "dependencies"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$",
                "description": "Spec name in kebab-case"
              },
              "status": {
                "type": "string",
                "enum": ["pending", "in_progress", "completed", "cancelled"],
                "description": "Spec completion status within the epic"
              },
              "dependencies": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "description": "Names of specs that must complete before this one"
              }
            }
          },
          "description": "Ordered list of specs in this epic with dependency graph"
        },
        "output": {
          "type": "string",
          "enum": ["spec-files", "github-issues", "both"],
          "description": "Where the epic plan was stored"
        },
        "issueNumber": {
          "type": ["integer", "null"],
          "description": "GitHub parent issue number (if output includes github-issues)"
        }
      }
    },

    "task": {
      "type": "object",
      "description": "Individual task structure in tasks.md",
      "required": ["id", "do", "files", "done_when", "verify"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Task ID in Phase.Task format (e.g., 1.2)"
        },
        "do": {
          "type": "string",
          "description": "Exact implementation steps"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths to create or modify"
        },
        "done_when": {
          "type": "string",
          "description": "Explicit success criteria"
        },
        "verify": {
          "type": "string",
          "description": "Command to verify completion"
        },
        "commit": {
          "type": "string",
          "description": "Conventional commit message"
        },
        "requirements_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Referenced requirement IDs"
        },
        "design_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Referenced design sections"
        }
      }
    },

    "researchFrontmatter": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "phase": { "const": "research" },
        "created": { "type": "string", "format": "date-time" }
      }
    },

    "requirementsFrontmatter": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "phase": { "const": "requirements" },
        "created": { "type": "string", "format": "date-time" }
      }
    },

    "designFrontmatter": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "phase": { "const": "design" },
        "created": { "type": "string", "format": "date-time" }
      }
    },

    "tasksFrontmatter": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "phase": { "const": "tasks" },
        "total_tasks": { "type": "integer" },
        "created": { "type": "string", "format": "date-time" }
      }
    },

    "progressFrontmatter": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "phase": { "type": "string" },
        "task": { "type": "string", "pattern": "^[0-9]+/[0-9]+$" },
        "updated": { "type": "string", "format": "date-time" }
      }
    },

    "indexState": {
      "type": "object",
      "description": "State for codebase indexing tracking",
      "properties": {
        "indexed": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last indexing run"
        },
        "componentCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of component specs generated"
        },
        "externalCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of external resource specs generated"
        },
        "excludes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Patterns excluded during indexing"
        },
        "paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths that were indexed"
        },
        "categories": {
          "type": "object",
          "description": "Component counts by category",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },

    "componentSpec": {
      "type": "object",
      "description": "Frontmatter for component spec files in specs/.index/components/",
      "required": ["type", "generated", "source", "hash", "category", "indexed"],
      "properties": {
        "type": {
          "type": "string",
          "const": "component-spec",
          "description": "Spec type identifier"
        },
        "generated": {
          "type": "boolean",
          "const": true,
          "description": "Indicates auto-generated spec"
        },
        "source": {
          "type": "string",
          "description": "Source file path relative to repo root"
        },
        "hash": {
          "type": "string",
          "description": "Content hash for change detection"
        },
        "category": {
          "type": "string",
          "enum": ["controllers", "services", "models", "helpers", "migrations", "other"],
          "description": "Component category"
        },
        "indexed": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when indexed"
        }
      }
    },

    "externalSpec": {
      "type": "object",
      "description": "Frontmatter for external resource spec files in specs/.index/external/",
      "required": ["type", "generated", "source-type", "source-id", "fetched"],
      "properties": {
        "type": {
          "type": "string",
          "const": "external-spec",
          "description": "Spec type identifier"
        },
        "generated": {
          "type": "boolean",
          "const": true,
          "description": "Indicates auto-generated spec"
        },
        "source-type": {
          "type": "string",
          "enum": ["url", "mcp", "skill"],
          "description": "Type of external resource"
        },
        "source-id": {
          "type": "string",
          "description": "URL, MCP server name, or skill identifier"
        },
        "fetched": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when resource was fetched"
        }
      }
    },

    "ciCommand": {
      "type": "object",
      "description": "A CI command with its classification category",
      "required": ["command", "category"],
      "properties": {
        "command": {
          "type": "string",
          "description": "The CI command to execute (e.g., pytest, ruff check ., mypy .)"
        },
        "category": {
          "type": "string",
          "enum": ["lint", "typecheck", "test", "build", "other"],
          "description": "Category of the CI command for per-category snapshot tracking"
        }
      }
    },

    "ciResult": {
      "type": "object",
      "description": "Per-category CI execution result",
      "properties": {
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "skip"],
          "description": "Execution outcome: pass, fail, or skip (missing binary)"
        },
        "exitCode": {
          "type": "integer",
          "description": "Process exit code"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of execution"
        },
        "iteration": {
          "type": "integer",
          "description": "globalIteration at execution time"
        },
        "command": {
          "type": "string",
          "description": "The command that was executed"
        }
      }
    },

    "securityDecisionEvent": {
      "type": "object",
      "description": "Security decision event appended to signals.jsonl by pre-execution-check.sh",
      "required": ["type", "decision", "layer", "risk", "agent", "task", "reason", "timestamp", "iteration"],
      "properties": {
        "type": {
          "const": "security-decision",
          "description": "Event type: security decision from pre-execution check"
        },
        "decision": {
          "type": "string",
          "enum": ["allow", "block", "confirm"],
          "description": "Verdict: allow (exit 0), block (hard-block role-contract), confirm (risky operation)"
        },
        "layer": {
          "type": "string",
          "enum": ["role-contract", "shell-pattern", "risk", "none"],
          "description": "Layer that drove the verdict; none = clean LOW/MEDIUM allow"
        },
        "risk": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"],
          "description": "Combined max-severity risk"
        },
        "agent": {
          "type": "string",
          "description": "Target agent role (e.g. spec-executor, qa-engineer)"
        },
        "task": {
          "type": "string",
          "description": "Task ID (e.g. 1.3)"
        },
        "path": {
          "type": ["string", "null"],
          "description": "Offending or relevant write path; null when not path-driven"
        },
        "command": {
          "type": ["string", "null"],
          "description": "Offending or relevant shell command; null when not command-driven"
        },
        "reason": {
          "type": "string",
          "description": "Human-readable reason (mirrors stderr)"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 UTC timestamp of decision"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "description": "globalIteration from .ralph-state.json at decision time"
        }
      }
    }
  }
}
